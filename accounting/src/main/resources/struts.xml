<struts>
    <package name="accounting" namespace="/" extends="struts-default">
        <action name="login" class="com.example.accounting.action.LoginAction">
            <result name="input">/WEB-INF/jsp/login.jsp</result>
            <result name="success" type="redirect">list</result>
        </action>
        <action name="logout" class="com.example.accounting.action.LogoutAction">
            <result type="redirect">login</result>
        </action>
        <action name="entry" class="com.example.accounting.action.EntryAction">
            <interceptor-ref name="defaultStack"/>
            <result name="input">/WEB-INF/jsp/entry.jsp</result>
            <result name="success" type="redirect">list</result>
        </action>
        <action name="list" class="com.example.accounting.action.ListAction">
            <result>/WEB-INF/jsp/list.jsp</result>
        </action>
        <action name="delete" class="com.example.accounting.action.DeleteAction">
            <result type="redirect">list</result>
        </action>
    </package>
</struts>
